# Copy to .env and fill in. .env is gitignored.

# --- Factorio RCON ---
# Enable RCON in Factorio by launching with: --rcon-port 27015 --rcon-password <pw>
RCON_HOST=127.0.0.1
RCON_PORT=27015
RCON_PASSWORD=change-me

# --- Backend <-> MCP shared secret ---
# Any random string; both backend and MCP must see the same value.
API_KEY=change-me-too

# --- MCP -> backend URL ---
BACKEND_URL=http://127.0.0.1:8000
